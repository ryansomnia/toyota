// prisma/schema.prisma
// Jalankan: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// MOBIL
// ─────────────────────────────────────────

model Car {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(100)
  brand       String   @db.VarChar(50)
  model       String   @db.VarChar(100)
  variant     String?  @db.VarChar(100)
  type        CarType
  year        Int
  price       Decimal  @db.Decimal(15, 0)   // harga OTR dalam rupiah
  priceMin    Decimal? @db.Decimal(15, 0)   // harga kredit terendah (opsional)
  fuel        FuelType
  transmission TransmissionType
  seats       Int      @default(5)
  engine      String?  @db.VarChar(50)      // contoh: "2.8L Turbo Diesel"
  color       String?  @db.VarChar(50)
  mileage     Int      @default(0)          // km, 0 = baru
  condition   CarCondition @default(NEW)
  badge       CarBadge?
  description String?  @db.Text
  features    String?  @db.Text             // JSON array fitur unggulan
  images      String?  @db.Text             // JSON array URL gambar
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
leads   Lead[]
promos      PromoCar[]
  @@index([brand])
  @@index([type])
  @@index([isActive])
  @@index([isFeatured])
  @@index([price])
  @@map("cars")
}

enum CarType {
  SUV
  MPV
  SEDAN
  CITY_CAR
  PICKUP
  SPORT
  COMMERCIAL
}

enum FuelType {
  BENSIN
  DIESEL
  HYBRID
  ELECTRIC
  LPG
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  CVT
  DCT
}

enum CarCondition {
  NEW
  USED
}

enum CarBadge {
  HOT
  NEW
  PROMO
  SOLD
}

// ─────────────────────────────────────────
// LEADS (calon pembeli)
// ─────────────────────────────────────────

model Lead {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(100)
  phone     String     @db.VarChar(20)
  email     String?    @db.VarChar(100)
  city      String?    @db.VarChar(50)
  budget    String?    @db.VarChar(50)      // "200-350 Juta"
  message   String?    @db.Text
  source    LeadSource @default(WEBSITE)
  status    LeadStatus @default(NEW)
  notes     String?    @db.Text             // catatan internal sales
  carId     Int?                            // mobil yang diminati
  car       Car?       @relation(fields: [carId], references: [id], onDelete: SetNull)
  followedAt DateTime?
  closedAt   DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
  @@index([phone])
  @@index([createdAt])
  @@map("leads")
}

enum LeadSource {
  WEBSITE
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  REFERRAL
  WALK_IN
  PHONE
}

enum LeadStatus {
  NEW         // baru masuk
  CONTACTED   // sudah dihubungi
  INTERESTED  // tertarik, sedang negosiasi
  TEST_DRIVE  // sudah test drive
  CLOSING     // proses closing
  WON         // berhasil beli
  LOST        // tidak jadi
}

// ─────────────────────────────────────────
// PROMO
// ─────────────────────────────────────────

model Promo {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(150)
  slug        String    @unique @db.VarChar(100)
  description String?   @db.Text
  type        PromoType
  discount    Decimal?  @db.Decimal(15, 0)  // nilai diskon dalam rupiah
  discountPct Decimal?  @db.Decimal(5, 2)   // persen diskon
  dpMinPct    Decimal?  @db.Decimal(5, 2)   // DP minimum persen
  imageUrl    String?   @db.VarChar(255)
  terms       String?   @db.Text            // syarat & ketentuan
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean   @default(true)
  isFeatured  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

cars        PromoCar[]
  @@index([isActive])
  @@index([startDate, endDate])
  @@map("promos")
}

enum PromoType {
  CASH_BACK
  DP_RINGAN
  FREE_AKSESORIS
  ASURANSI_GRATIS
  TUKAR_TAMBAH
  CICILAN_RINGAN
  BUNDLE
}

// Pivot: promo berlaku untuk mobil tertentu
model PromoCar { 
  promoId Int
  carId   Int
  promo   Promo @relation(fields: [promoId], references: [id], onDelete: Cascade)
  car     Car   @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@id([promoId, carId])
  @@map("promo_cars")
}

// ─────────────────────────────────────────
// TESTIMONIAL
// ─────────────────────────────────────────

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  city      String?  @db.VarChar(50)
  carBought String?  @db.VarChar(100)      // "Toyota Fortuner 2024"
  rating    Int      @default(5)           // 1–5
  content   String   @db.Text
  avatarUrl String?  @db.VarChar(255)
  isActive  Boolean  @default(true)
  isFeatured Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([isActive])
  @@index([rating])
  @@map("testimonials")
}

// ─────────────────────────────────────────
// BLOG / ARTIKEL
// ─────────────────────────────────────────

model Article {
  id          Int           @id @default(autoincrement())
  slug        String        @unique @db.VarChar(150)
  title       String        @db.VarChar(200)
  excerpt     String?       @db.VarChar(300)
  content     String        @db.LongText
  category    ArticleCategory
  tags        String?       @db.VarChar(255) // CSV: "toyota,fortuner,review"
  imageUrl    String?       @db.VarChar(255)
  metaTitle   String?       @db.VarChar(70)  // SEO
  metaDesc    String?       @db.VarChar(160) // SEO
  isPublished Boolean       @default(false)
  publishedAt DateTime?
  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([isPublished])
  @@index([category])
  @@index([publishedAt])
  @@map("articles")
}

enum ArticleCategory {
  REVIEW
  TIPS
  PROMO
  BERITA
  KREDIT
  PERAWATAN
}

// ─────────────────────────────────────────
// KREDIT SIMULATION LOG (opsional, analytics)
// ─────────────────────────────────────────

model CreditSimulation {
  id        Int      @id @default(autoincrement())
  carPrice  Decimal  @db.Decimal(15, 0)
  dpPercent Int
  tenor     Int      // bulan
  monthly   Decimal  @db.Decimal(15, 0)
  phone     String?  @db.VarChar(20)  // diisi kalau mau difollow up
  createdAt DateTime @default(now())

  @@map("credit_simulations")
}
