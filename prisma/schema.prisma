// ============================================================
//  AutoPrima – Prisma Schema (Toyota Single Brand)
//  Database: toyota (MySQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// ENUMS
// ------------------------------------------------------------

enum FuelType {
  Bensin
  Diesel
  Hybrid
  HybridEV   @map("Hybrid EV")
  BatteryEV  @map("Battery EV")
}

enum TransmissionType {
  Manual
  Automatic
  CVT
  eCVT              @map("e-CVT")
  DirectShiftCVT    @map("Direct Shift CVT")
}

enum Drivetrain {
  FourByTwo  @map("4x2")
  FourByFour @map("4x4")
  FWD
  AWD
  eFour      @map("e-Four")
}

enum ImageCategory {
  exterior
  interior
  detail
  color
  banner
}

enum DiscountType {
  cashback
  dp_ringan
  free_item
  bonus
  other
}

// ------------------------------------------------------------
// 1. CAR_CATEGORIES
// ------------------------------------------------------------
model CarCategory {
  id          Int        @id @default(autoincrement()) @db.UnsignedInt
  name        String     @db.VarChar(100)         // "SUV", "MPV"
  slug        String     @unique @db.VarChar(110) // "suv", "mpv"
  description String?    @db.Text
  icon        String?    @db.VarChar(10)          // emoji
  sortOrder   Int        @default(0) @map("sort_order") @db.UnsignedTinyInt
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")

  models      CarModel[]

  @@map("car_categories")
}

// ------------------------------------------------------------
// 2. CAR_MODELS
// ------------------------------------------------------------
model CarModel {
  id            Int         @id @default(autoincrement()) @db.UnsignedInt
  categoryId    Int         @db.UnsignedInt @map("category_id")
  name          String      @db.VarChar(200)       // "Fortuner"
  fullName      String      @db.VarChar(200) @map("full_name") // "New Fortuner GR Sport"
  slug          String      @unique @db.VarChar(220)
  tagline       String?     @db.VarChar(300)       // "Discover Your Fortuner"
  description   String?     @db.Text

  // Media
  bannerUrl     String?     @db.VarChar(500) @map("banner_url")
  thumbnailUrl  String?     @db.VarChar(500) @map("thumbnail_url")
  brochureUrl   String?     @db.VarChar(500) @map("brochure_url")

  // Harga terendah untuk listing
  startingPrice Decimal?    @db.Decimal(15, 2) @map("starting_price")
  priceLabel    String      @default("Starting from") @db.VarChar(50) @map("price_label")

  // Label & Status
  label         String?     @db.VarChar(50)        // "NEW", "HYBRID", "EV", "GR"
  isNew         Boolean     @default(false) @map("is_new")
  isFeatured    Boolean     @default(false) @map("is_featured")
  isActive      Boolean     @default(true) @map("is_active")
  sortOrder     Int         @default(0) @db.UnsignedSmallInt @map("sort_order")
  viewCount     Int         @default(0) @db.UnsignedInt @map("view_count")

  // SEO
  metaTitle       String?   @db.VarChar(160) @map("meta_title")
  metaDescription String?   @db.VarChar(320) @map("meta_description")

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // Relations
  category      CarCategory   @relation(fields: [categoryId], references: [id])
  variants      CarVariant[]
  colors        CarColor[]
  images        CarImage[]
  features      CarFeature[]
  promos        Promo[]
  testimonials  Testimonial[]

  @@index([categoryId])
  @@index([isFeatured])
  @@index([isActive])
  @@map("car_models")
}

// ------------------------------------------------------------
// 3. CAR_VARIANTS
// ------------------------------------------------------------
model CarVariant {
  id            Int              @id @default(autoincrement()) @db.UnsignedInt
  modelId       Int              @db.UnsignedInt @map("model_id")
  name          String           @db.VarChar(200)  // "GR Sport", "G", "HEV"
  slug          String           @unique @db.VarChar(220)
  fuel          FuelType         @default(Bensin)
  transmission  TransmissionType @default(Automatic)
  engineCc      Int?             @db.UnsignedSmallInt @map("engine_cc")
  engineLabel   String?          @db.VarChar(100) @map("engine_label") // "2.8L Turbo Diesel"
  drivetrain    Drivetrain       @default(FourByTwo)
  seats         Int              @default(7) @db.UnsignedTinyInt
  isActive      Boolean          @default(true) @map("is_active")
  sortOrder     Int              @default(0) @db.UnsignedSmallInt @map("sort_order")
  createdAt     DateTime         @default(now()) @map("created_at")

  model         CarModel     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  prices        CarPrice[]
  images        CarImage[]
  specs         CarSpec[]

  @@index([modelId])
  @@map("car_variants")
}

// ------------------------------------------------------------
// 4. CAR_PRICES
// ------------------------------------------------------------
model CarPrice {
  id             Int      @id @default(autoincrement()) @db.UnsignedInt
  variantId      Int      @db.UnsignedInt @map("variant_id")
  label          String   @db.VarChar(250)  // "2.7 SRZ 4x2 A/T Non RSE"
  price          Decimal? @db.Decimal(15, 2)// NULL = Hubungi Kami
  priceOnRequest Boolean  @default(false) @map("price_on_request")
  isBasePrice    Boolean  @default(false) @map("is_base_price")
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @db.UnsignedTinyInt @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  variant        CarVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@map("car_prices")
}

// ------------------------------------------------------------
// 5. CAR_COLORS
// ------------------------------------------------------------
model CarColor {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  modelId   Int      @db.UnsignedInt @map("model_id")
  name      String   @db.VarChar(150)               // "Attitude Black Mica"
  hexCode   String?  @db.VarChar(7) @map("hex_code")// "#1C1C1C"
  imageUrl  String?  @db.VarChar(500) @map("image_url")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @db.UnsignedTinyInt @map("sort_order")

  model     CarModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("car_colors")
}

// ------------------------------------------------------------
// 6. CAR_IMAGES
// ------------------------------------------------------------
model CarImage {
  id          Int           @id @default(autoincrement()) @db.UnsignedInt
  modelId     Int           @db.UnsignedInt @map("model_id")
  variantId   Int?          @db.UnsignedInt @map("variant_id")
  url         String        @db.VarChar(500)
  altText     String?       @db.VarChar(200) @map("alt_text")
  category    ImageCategory @default(exterior)
  isPrimary   Boolean       @default(false) @map("is_primary")
  sortOrder   Int           @default(0) @db.UnsignedTinyInt @map("sort_order")
  createdAt   DateTime      @default(now()) @map("created_at")

  model       CarModel    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  variant     CarVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([modelId])
  @@index([variantId])
  @@map("car_images")
}

// ------------------------------------------------------------
// 7. CAR_FEATURES
// ------------------------------------------------------------
model CarFeature {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  modelId     Int      @db.UnsignedInt @map("model_id")
  title       String   @db.VarChar(200)              // "Toyota Safety Sense"
  description String?  @db.Text
  iconUrl     String?  @db.VarChar(500) @map("icon_url")
  imageUrl    String?  @db.VarChar(500) @map("image_url")
  category    String?  @db.VarChar(100)              // "Safety","Comfort","Performance"
  sortOrder   Int      @default(0) @db.UnsignedSmallInt @map("sort_order")

  model       CarModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("car_features")
}

// ------------------------------------------------------------
// 8. CAR_SPECS — spesifikasi teknis per varian (key-value)
// ------------------------------------------------------------
model CarSpec {
  id          Int        @id @default(autoincrement()) @db.UnsignedInt
  variantId   Int        @db.UnsignedInt @map("variant_id")
  category    String     @db.VarChar(100)   // "Mesin","Dimensi","Keselamatan"
  specKey     String     @db.VarChar(150) @map("spec_key")    // "Kapasitas Mesin"
  specValue   String     @db.VarChar(300) @map("spec_value")  // "2.755 cc"
  sortOrder   Int        @default(0) @db.UnsignedSmallInt @map("sort_order")

  variant     CarVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@map("car_specs")
}

// ------------------------------------------------------------
// 9. PROMOS
// ------------------------------------------------------------
model Promo {
  id            Int          @id @default(autoincrement()) @db.UnsignedInt
  title         String       @db.VarChar(200)
  slug          String       @unique @db.VarChar(220)
  description   String?      @db.Text
  terms         String?      @db.Text
  discountType  DiscountType @map("discount_type")
  discountValue Decimal?     @db.Decimal(15, 2) @map("discount_value")
  modelId       Int?         @db.UnsignedInt @map("model_id") // null = semua model
  startDate     DateTime     @map("start_date")
  endDate       DateTime     @map("end_date")
  bannerUrl     String?      @db.VarChar(500) @map("banner_url")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  model         CarModel?    @relation(fields: [modelId], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([startDate, endDate])
  @@map("promos")
}

// ------------------------------------------------------------
// 10. TESTIMONIALS
// ------------------------------------------------------------
model Testimonial {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  nama        String   @db.VarChar(150)
  kota        String?  @db.VarChar(100)
  modelId     Int?     @db.UnsignedInt @map("model_id")
  carName     String?  @db.VarChar(200) @map("car_name") // teks bebas jika modelId null
  rating      Int      @default(5) @db.UnsignedTinyInt
  quote       String   @db.Text
  avatarUrl   String?  @db.VarChar(500) @map("avatar_url")
  isFeatured  Boolean  @default(false) @map("is_featured")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  model       CarModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)

  @@index([isFeatured])
  @@index([isActive])
  @@map("testimonials")
}

// ------------------------------------------------------------
// 11. SETTINGS
// ------------------------------------------------------------
model Setting {
  key       String   @id @db.VarChar(100)
  value     String?  @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
